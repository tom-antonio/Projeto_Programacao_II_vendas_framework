	<queryString language="SQL"><![CDATA[SELECT cliente.nome,
	cliente.nome,
	venda.data_venda,
	venda.valor_total,
	produtovenda.qtdeproduto,
	produtovenda.valorunit,
	produto.nome,
	venda.data_venda,
	venda.valor_total
FROM produtovenda
	INNER JOIN venda ON 
	 produtovenda.id_venda = venda.id 
	INNER JOIN cliente ON 
	 venda.cliente_id = cliente.id 
	INNER JOIN produto ON 
	 produtovenda.id_produto = produto.id]]></queryString>
